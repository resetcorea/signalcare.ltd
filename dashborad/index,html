<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>SignalCare — Paid Service Demo Version</title>
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ─── TOKENS ─── */
:root{
  --bg:#03040a;--s0:#060810;--s1:#0a0c18;--s2:#0f1122;--s3:#14162c;--s4:#1a1d38;
  --t1:#eef0ff;--t2:#6e72a8;--t3:#32365a;--t4:#1e2040;
  --ac:#c6f135;--ac2:rgba(198,241,53,.09);--ac3:rgba(198,241,53,.22);
  --cy:#00d0ff;--cy2:rgba(0,208,255,.09);
  --vi:#9b7dff;--vi2:rgba(155,125,255,.09);
  --gd:#f0c040;--gd2:rgba(240,192,64,.09);
  --rd:#ff4560;--rd2:rgba(255,69,96,.09);
  --gn:#2ecc71;--gn2:rgba(46,204,113,.09);
  --b1:#181c38;--b2:#22274a;--b3:#2e3460;
  --sw:244px;--swm:56px;--th:52px;
  --fs:"Pretendard Variable","Pretendard",-apple-system,sans-serif;
  --fm:"JetBrains Mono","SF Mono",monospace;
  --ez:cubic-bezier(.22,1,.36,1);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-font-smoothing:antialiased}
html{color-scheme:dark;font-size:13px}
body{background:var(--bg);color:var(--t1);font-family:var(--fs);min-height:100vh;overflow-x:hidden}
::selection{background:var(--ac2);color:var(--ac)}
::-webkit-scrollbar{width:3px;height:3px}::-webkit-scrollbar-thumb{background:var(--b2);border-radius:2px}
button,select{font-family:inherit;cursor:pointer;background:none;border:none;color:inherit;outline:none}

/* atmospheric */
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background:radial-gradient(ellipse 70% 50% at 15% 0%,rgba(198,241,53,.04),transparent 60%),
             radial-gradient(ellipse 50% 40% at 85% 100%,rgba(0,208,255,.03),transparent 60%)}
body::after{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(var(--b1) 1px,transparent 1px),linear-gradient(90deg,var(--b1) 1px,transparent 1px);
  background-size:52px 52px;opacity:.28}

/* ─── SHELL ─── */
.shell{position:relative;z-index:1;display:flex;min-height:100vh}

/* ─── SIDEBAR ─── */
.sidebar{width:var(--sw);flex-shrink:0;background:rgba(6,8,16,.96);border-right:1px solid var(--b1);
  display:flex;flex-direction:column;position:fixed;top:0;bottom:0;left:0;
  backdrop-filter:blur(28px);z-index:60;transition:width .28s var(--ez);overflow:hidden}
.sidebar.mini{width:var(--swm)}
.sidebar.mini .sb-lbl,.sidebar.mini .brand-name,.sidebar.mini .brand-tag,
.sidebar.mini .sb-sec,.sidebar.mini .nb,.sidebar.mini .sf-txt{display:none!important}

.brand{display:flex;align-items:center;gap:11px;padding:18px 14px 16px;border-bottom:1px solid var(--b1);flex-shrink:0;position:relative}
.brand-mark{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,var(--ac),var(--cy));
  display:flex;align-items:center;justify-content:center;font-weight:900;font-size:14px;color:#000;
  flex-shrink:0;box-shadow:0 0 20px rgba(198,241,53,.2)}
.brand-name{font-size:13px;font-weight:800;letter-spacing:-.02em;line-height:1.15}
.brand-name em{color:var(--ac);font-style:normal}
.brand-tag{font-size:7.5px;color:var(--t3);font-family:var(--fm);letter-spacing:.07em;text-transform:uppercase;margin-top:1px}
.sb-tog{position:absolute;right:-14px;top:50%;transform:translateY(-50%);width:28px;height:28px;
  border-radius:50%;background:var(--s2);border:1px solid var(--b2);
  display:flex;align-items:center;justify-content:center;color:var(--t2);font-size:10px;cursor:pointer;transition:all .18s}
.sb-tog:hover{color:var(--t1);background:var(--b2)}

.nav-wrap{flex:1;overflow-y:auto;overflow-x:hidden;padding:6px 0 10px}
.nav-wrap::-webkit-scrollbar{display:none}
.sb-sec{font-size:7.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  color:var(--t3);padding:14px 16px 4px;font-family:var(--fm);white-space:nowrap}
.ni{display:flex;align-items:center;gap:9px;padding:8px 14px;margin:1px 6px;border-radius:9px;
  font-size:12px;font-weight:500;color:var(--t2);cursor:pointer;transition:all .16s;
  white-space:nowrap;user-select:none;position:relative}
.ni:hover{background:var(--s3);color:var(--t1)}
.ni.on{background:var(--ac2);color:var(--ac);font-weight:700;border:1px solid var(--ac3)}
.ni.on::before{content:'';position:absolute;left:0;top:20%;bottom:20%;width:3px;background:var(--ac);border-radius:0 3px 3px 0}
.ni-ico{font-size:15px;flex-shrink:0;width:18px;text-align:center}
.sb-lbl{flex:1;overflow:hidden;text-overflow:ellipsis}
.nb{font-size:7.5px;font-weight:700;font-family:var(--fm);padding:2px 6px;border-radius:6px;flex-shrink:0;letter-spacing:.04em}
.nb-ac{background:var(--ac2);color:var(--ac)}.nb-gn{background:var(--gn2);color:var(--gn)}
.nb-vi{background:var(--vi2);color:var(--vi)}.nb-rd{background:var(--rd2);color:var(--rd)}

.sf{border-top:1px solid var(--b1);padding:10px 8px;flex-shrink:0}
.sf-live{display:flex;align-items:center;gap:6px;padding:5px 8px;font-size:9px;color:var(--t2);font-family:var(--fm)}
.sf-live::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--ac);flex-shrink:0;animation:lp 2s ease-in-out infinite}
.sf-sys{display:flex;align-items:center;gap:6px;padding:5px 8px;font-size:9px;color:var(--t3);font-family:var(--fm)}
.sf-sys::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--gn);flex-shrink:0;animation:lp 3s ease-in-out infinite}

/* ─── MAIN ─── */
.main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;min-height:100vh;transition:margin-left .28s var(--ez)}
.main.wide{margin-left:var(--swm)}

.topbar{height:var(--th);display:flex;align-items:center;justify-content:space-between;padding:0 24px;
  border-bottom:1px solid var(--b1);background:rgba(3,4,10,.88);backdrop-filter:blur(24px);
  position:sticky;top:0;z-index:50;flex-shrink:0;gap:12px}
.tb-l{display:flex;align-items:center;gap:14px;min-width:0}
.tb-pg{font-size:14px;font-weight:700;letter-spacing:-.015em;white-space:nowrap}
.tb-bc{font-size:9px;font-family:var(--fm);color:var(--t3)}
.tb-r{display:flex;align-items:center;gap:8px;flex-shrink:0}
.tb-hash{font-family:var(--fm);font-size:9px;color:rgba(198,241,53,.35);white-space:nowrap}
.tb-sel{font-family:var(--fm);font-size:10px;font-weight:600;padding:5px 10px;border-radius:7px;background:var(--s2);border:1px solid var(--b2);color:var(--ac)}
.tb-cur{padding:5px 10px;border-radius:7px;background:var(--s2);border:1px solid var(--b2);font-family:var(--fm);font-size:10px;color:var(--t1)}
.tb-btn{display:flex;align-items:center;gap:5px;padding:6px 14px;border-radius:8px;font-size:11px;font-weight:700;border:1px solid var(--b2);color:var(--t2);transition:all .16s;white-space:nowrap}
.tb-btn:hover{background:var(--s2);color:var(--t1)}
.tb-btn.pri{background:var(--ac);color:#000;border-color:transparent;box-shadow:0 0 22px rgba(198,241,53,.18)}
.tb-btn.pri:hover{background:rgba(198,241,53,.88)}

.cnt{padding:22px 24px 52px;flex:1}

/* ─── COMPONENTS ─── */
/* kpi */
.krow{display:grid;gap:12px;margin-bottom:16px}
.k6{grid-template-columns:repeat(6,1fr)}.k4{grid-template-columns:repeat(4,1fr)}.k3{grid-template-columns:repeat(3,1fr)}
.kc{background:var(--s1);border:1px solid var(--b1);border-radius:12px;padding:14px 16px;transition:border-color .2s,transform .18s}
.kc:hover{border-color:var(--b2);transform:translateY(-1px)}
.kc-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px}
.kc-lbl{font-size:8.5px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t2);font-family:var(--fm)}
.kc-ico{font-size:14px;opacity:.65}
.kc-num{font-size:clamp(18px,2vw,26px);font-weight:700;letter-spacing:-.03em;line-height:1;font-variant-numeric:tabular-nums}
.kc-sub{font-size:9px;color:var(--t2);margin-top:5px}
.up{color:var(--gn)}.dn{color:var(--rd)}.nu{color:var(--cy)}

/* card */
.card{background:var(--s1);border:1px solid var(--b1);border-radius:14px;overflow:hidden;transition:border-color .2s}
.card:hover{border-color:var(--b2)}
.ch{display:flex;align-items:flex-start;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--b1);gap:10px}
.ct{font-size:12px;font-weight:700;display:flex;align-items:center;gap:7px}
.cs{font-size:9px;color:var(--t2);margin-top:3px;font-family:var(--fm)}
.cb{padding:16px 18px}.cb0{/* no-pad */}

/* badge — unified system */
.bd{display:inline-flex;align-items:center;gap:4px;font-size:8px;font-weight:700;
  text-transform:uppercase;letter-spacing:.07em;padding:2px 8px;border-radius:5px;
  font-family:var(--fm);flex-shrink:0;white-space:nowrap}
.bd.dot::before{content:'';display:block;width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0;animation:lp 2s ease-in-out infinite}
.bd-ac{background:var(--ac2);color:var(--ac)}.bd-gn{background:var(--gn2);color:var(--gn)}
.bd-rd{background:var(--rd2);color:var(--rd)}.bd-cy{background:var(--cy2);color:var(--cy)}
.bd-vi{background:var(--vi2);color:var(--vi)}.bd-gd{background:var(--gd2);color:var(--gd)}

/* grids */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}
.g21{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:14px}
.g12{display:grid;grid-template-columns:1fr 2fr;gap:14px;margin-bottom:14px}
.gf{margin-bottom:14px}

/* table */
.tbl{width:100%;border-collapse:collapse}
.tbl th{font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--t2);font-family:var(--fm);padding:9px 14px;text-align:left;border-bottom:1px solid var(--b1)}
.tbl td{padding:10px 14px;font-size:11px;border-bottom:1px solid rgba(24,28,56,.6);vertical-align:middle}
.tbl tr:last-child td{border-bottom:none}
.tbl tr:hover td{background:rgba(255,255,255,.015)}
.mono{font-family:var(--fm)}
.hcell{font-family:var(--fm);font-size:8.5px;color:rgba(198,241,53,.35);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:140px}

/* progress */
.pg{height:4px;background:var(--b1);border-radius:2px;overflow:hidden}
.pg5{height:5px}.pg7{height:7px}
.pf{height:100%;border-radius:2px;transition:width 1.5s var(--ez)}

/* stat row */
.sr{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(24,28,56,.5);font-size:11px}
.sr:last-child{border-bottom:none}
.sr-l{color:var(--t2)}.sr-v{font-weight:700;font-family:var(--fm)}

/* chart */
.cw{position:relative;width:100%}
.cw svg{width:100%;overflow:visible}
.gl{stroke:var(--b1);stroke-width:1}
.cl-ac{stroke:var(--ac);stroke-width:2.5;fill:none;stroke-linecap:round;stroke-linejoin:round}
.cl-cy{stroke:var(--cy);stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round}
.cl-vi{stroke:var(--vi);stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round}
.ca-ac{fill:rgba(198,241,53,.07)}.ca-cy{fill:rgba(0,208,255,.05)}
.ax{fill:var(--t2);font-size:9px;font-family:var(--fs);font-weight:600}

/* hash stream */
.hs{display:flex;flex-direction:column;gap:1px;overflow:hidden}
.hr{display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid rgba(24,28,56,.4);animation:si .3s var(--ez)}
.hts{font-family:var(--fm);font-size:8px;color:var(--cy);width:62px;flex-shrink:0}
.hv{font-family:var(--fm);font-size:8px;color:rgba(198,241,53,.32);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hn{font-family:var(--fm);font-size:7px;font-weight:700;background:var(--ac2);color:var(--ac);padding:1px 5px;border-radius:3px;flex-shrink:0}

/* security checks */
.sci{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(24,28,56,.45)}
.sci:last-child{border-bottom:none}
.sci-l{display:flex;align-items:center;gap:8px;font-size:11px}
.st{font-size:8px;font-weight:700;font-family:var(--fm);padding:2px 7px;border-radius:4px;letter-spacing:.06em}
.pass{background:var(--gn2);color:var(--gn)}.warn{background:var(--gd2);color:var(--gd)}.fail{background:var(--rd2);color:var(--rd)}

/* region card */
.rc{background:var(--s2);border:1px solid var(--b1);border-radius:12px;padding:14px;
  position:relative;overflow:hidden;transition:border-color .2s,transform .2s;cursor:pointer}
.rc:hover{border-color:var(--b2);transform:translateY(-2px)}
.rc-bar{position:absolute;top:0;left:0;right:0;height:3px}

/* billing formula */
.fbox{background:linear-gradient(135deg,rgba(198,241,53,.05),rgba(0,208,255,.04));
  border:1px solid var(--ac3);border-radius:14px;padding:20px 24px;text-align:center;margin-bottom:16px}
.ftxt{font-size:14px;color:rgba(180,210,180,.7);font-family:var(--fm);line-height:2.1}
.ftxt .hl{color:var(--ac);font-weight:700;font-size:16px}.ftxt .sp{color:var(--t3);padding:0 8px}

/* plan card */
.pc{background:var(--s1);border:1px solid var(--b1);border-radius:14px;padding:20px;transition:border-color .2s,transform .2s}
.pc:hover{transform:translateY(-2px)}
.pc.feat{border-color:var(--ac);box-shadow:0 0 28px rgba(198,241,53,.07)}
.pc-top{background:var(--ac);color:#000;font-size:8px;font-weight:700;letter-spacing:.08em;
  text-align:center;padding:3px;margin:-20px -20px 16px;border-radius:14px 14px 0 0}
.pc-name{font-size:18px;font-weight:800;margin-bottom:4px}
.pc-type{font-size:11px;color:var(--t2);font-family:var(--fm);margin-bottom:12px;line-height:1.5}
.pc-price{font-size:26px;font-weight:800;font-family:var(--fm);margin-bottom:4px;letter-spacing:-.02em}
.pc-per{font-size:12px;color:var(--t2);font-weight:700;margin-bottom:14px}
.pc-feat{font-size:11.5px;color:rgba(238,240,255,.74);line-height:1.9}
.pc-cta{display:flex;align-items:center;justify-content:center;margin-top:18px;padding:11px 14px;border-radius:10px;background:var(--ac);color:#000;text-decoration:none;font-size:12px;font-weight:900}
.pc-cta.alt{background:transparent;color:var(--cy);border:1px solid var(--cy)}

/* revenue bar */
.rvb{height:32px;border-radius:8px;overflow:hidden;display:flex;margin-bottom:10px}
.rvs{display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;font-family:var(--fm);letter-spacing:.02em;transition:width 1.2s var(--ez)}

/* mini stat */
.ms{background:var(--s2);border:1px solid var(--b1);border-radius:8px;padding:9px 11px}
.ms-l{font-size:7.5px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--t2);font-family:var(--fm);margin-bottom:3px}
.ms-v{font-size:13px;font-weight:700;font-family:var(--fm)}

/* alert box */
.abox{border-radius:9px;padding:11px 13px;font-size:10px;margin-bottom:8px}
.abox:last-child{margin-bottom:0}
.abox h4{font-weight:700;margin-bottom:3px}
.abox p{color:var(--t2);line-height:1.55}

/* ─── ANIMATIONS ─── */
@keyframes lp{0%,100%{opacity:1}50%{opacity:.25}}
@keyframes fu{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes si{from{opacity:0;transform:translateX(-6px)}to{opacity:1;transform:translateX(0)}}
@keyframes dp{from{stroke-dashoffset:700}to{stroke-dashoffset:0}}
@keyframes ci{from{opacity:0;transform:scale(.95) translateY(4px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes mp{0%,100%{r:5;opacity:.9}50%{r:10;opacity:.3}}
@keyframes sc{0%{transform:translateY(-100%)}100%{transform:translateY(100vh)}}

.fu{animation:fu .44s var(--ez) both}
.d0{animation-delay:0s}.d1{animation-delay:.07s}.d2{animation-delay:.14s}
.d3{animation-delay:.21s}.d4{animation-delay:.28s}.d5{animation-delay:.35s}
.dac{stroke-dasharray:700;stroke-dashoffset:700;animation:dp 2s var(--ez) .4s forwards}
.dcy{stroke-dasharray:700;stroke-dashoffset:700;animation:dp 2.3s var(--ez) .7s forwards}
.dvi{stroke-dasharray:700;stroke-dashoffset:700;animation:dp 2.5s var(--ez) .9s forwards}
.scan{position:fixed;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(198,241,53,.15),transparent);animation:sc 10s linear infinite;pointer-events:none;z-index:999}

/* ─── RESPONSIVE ─── */
@media(max-width:1280px){.k6{grid-template-columns:repeat(3,1fr)}.g3{grid-template-columns:1fr 1fr}}
@media(max-width:960px){.k4{grid-template-columns:repeat(2,1fr)}.g2,.g21,.g12{grid-template-columns:1fr}}
@media(max-width:768px){.sidebar{width:var(--swm)}.sidebar .sb-lbl,.sidebar .brand-name,.sidebar .brand-tag,.sidebar .sb-sec,.sidebar .nb,.sidebar .sf-txt{display:none!important}.main{margin-left:var(--swm)!important}}

.afu{animation:fu .45s var(--ez) both}

/* ── RTL (Arabic) ── */
[dir="rtl"] .sb { left: auto; right: 0; border-right: none; border-left: 1px solid var(--b1); }
[dir="rtl"] .main { margin-left: 0; margin-right: var(--sw); }
[dir="rtl"] .main.expanded { margin-left: 0; margin-right: 54px; }
[dir="rtl"] .topbar { direction: rtl; }
[dir="rtl"] .tb-left { flex-direction: row-reverse; }
[dir="rtl"] .tb-right { flex-direction: row-reverse; }
[dir="rtl"] .cnt { direction: rtl; }
[dir="rtl"] .krow { direction: rtl; }
[dir="rtl"] .g2, [dir="rtl"] .g3, [dir="rtl"] .g21, [dir="rtl"] .g12 { direction: rtl; }
[dir="rtl"] .card-head { flex-direction: row-reverse; }
[dir="rtl"] .card-title { flex-direction: row-reverse; }
[dir="rtl"] .ni { flex-direction: row-reverse; }
[dir="rtl"] .ni-ico { margin-left: 0; margin-right: 0; }
[dir="rtl"] .nb { margin-left: 0; margin-right: auto; }
[dir="rtl"] .tbl th, [dir="rtl"] .tbl td { text-align: right; }
[dir="rtl"] .collapse-btn { right: auto; left: -14px; }
[dir="rtl"] .sb-brand { flex-direction: row-reverse; }
</style>
</head>
<body>
<div class="scan"></div>

<!-- ══════════════════════════════════════════
  ALL DATA, i18n, NAV — single unified script
