  if(ttl)ttl.textContent=key==="billing"?(BILLING_COPY[ST.lang]||BILLING_COPY.ko).title:key==="carbonMap"?(MAP_COPY[ST.lang]||MAP_COPY.ko).title:key==="tenantRegions"?(TENANT_COPY[ST.lang]||TENANT_COPY.ko).title:key==="revenueShare"?(REVENUE_COPY[ST.lang]||REVENUE_COPY.ko).title:(pg.t||nt(key));
  if(bc)bc.textContent=nt(key);
  const pc=document.getElementById("PC");
  if(!pc)return;
  pc.style.opacity="0";pc.style.transform="translateY(6px)";
  setTimeout(()=>{
    pc.innerHTML=(PAGE_MAP[key]||pgGeneric.bind(null,key))();
    pc.style.transition="opacity .38s var(--ez),transform .38s var(--ez)";
    pc.style.opacity="1";pc.style.transform="translateY(0)";
    /* animate progress bars & chart annotations */
    requestAnimationFrame(()=>requestAnimationFrame(()=>{
      pc.querySelectorAll(".pf").forEach(el=>{const w=el.style.width;el.style.width="0";setTimeout(()=>{el.style.transition="width 1.4s var(--ez)";el.style.width=w;},50);});
      setTimeout(()=>{["pkDot","ltDot","pkLn","pkTxt"].forEach(id=>{const el=document.getElementById(id);if(el)el.style.opacity="1";});},2000);
    }));
    applyDashboardLanguage();
  },180);
}

/* ════════════════════ NAV BUILD ════════════════════ */
function buildNav(){
  const wrap=document.getElementById("navWrap");
  if(!wrap)return;
  wrap.innerHTML="";
  NAV.forEach(sec=>{
    const s=document.createElement("div");s.className="sb-sec";s.textContent=t(sec.sec)||sec.sec;wrap.appendChild(s);
    sec.items.forEach(item=>{
      const el=document.createElement("div");
      el.className="ni"+(item.k===ST.page?" on":"");
      el.dataset.k=item.k;
      el.innerHTML=`<span class="ni-ico">${item.i}</span><span class="sb-lbl">${nt(item.k)}</span>${item.nb?`<span class="nb ${item.nb.c}">${item.nb.t}</span>`:""}`;
      el.onclick=()=>goPage(item.k);
      wrap.appendChild(el);
    });
  });
}

/* ════════════════════ SIDEBAR TOGGLE ════════════════════ */
function toggleSB(){
  ST.mini=!ST.mini;
  document.getElementById("SB").classList.toggle("mini",ST.mini);
  document.getElementById("MA").classList.toggle("wide",ST.mini);
  const btn=document.getElementById("sbTog");if(btn)btn.textContent=ST.mini?"▶":"◀";
}

/* ════════════════════ LANG / CURRENCY ════════════════════ */
function setLang(code){
  ST.lang=code;
  const dir=(LANG[code]||LANG.en).dir;
  document.documentElement.setAttribute("lang",code);
  document.documentElement.setAttribute("dir",dir);
  buildNav();
  goPage(ST.page);
  setTimeout(applyDashboardLanguage,220);
  const sf=document.getElementById("sfSys");if(sf)sf.textContent=t("opn");
  const sfL=document.getElementById("sfLive");if(sfL)sfL.textContent="41 "+t("sov").toUpperCase()+" NODES";
}
function setCur(code){ST.cur=code;goPage(ST.page);}

async function logout(){
  try{await fetch("/api/logout",{method:"POST"});}catch(e){}
  location.href="/login";
}

/* ════════════════════ LIVE DATA ENGINE ════════════════════ */
function startLive(){
  /* SHA-256 hash stream */
  setInterval(()=>{
    const hs=document.getElementById("hashStream");
    if(!hs)return;
    const row=document.createElement("div");row.className="hr";
    row.innerHTML=`<span class="hts">${ts()}</span><span class="hv">${s64()}</span><span class="hn">NEW</span>`;
    hs.prepend(row);
    while(hs.children.length>9)hs.removeChild(hs.lastChild);
  },2400);

  /* Topbar hash ticker */
  setInterval(()=>{const el=document.getElementById("tbHash");if(el)el.textContent=s8()+"…";},2400);

  /* Live CH4 */
  setInterval(()=>{
    ST.liveCH4=Math.max(12,Math.min(18,ST.liveCH4+(Math.random()-.47)*.25));
    const el=document.getElementById("dCH4");if(el)el.textContent=`CH₄ ${ST.liveCH4.toFixed(2)} ppm`;
  },1800);

  /* Asset counter */
  setInterval(()=>{
    ST.liveAsset+=Math.random()*2.4;
    const el=document.getElementById("dAsset");
    if(el)el.textContent=C().s+Math.round(ST.liveAsset).toLocaleString("en-US");
  },3000);
}

/* ════════════════════ INIT ════════════════════ */
function init(){
  buildNav();
  goPage("dashboard");
  startLive();
  /* Keyboard shortcuts */
  document.addEventListener("keydown",e=>{
    if(e.target.tagName==="INPUT"||e.target.tagName==="SELECT")return;
    const m={d:"dashboard",m:"carbonMap",b:"billing",a:"auditLogs",s:"security",t:"tenantRegions",r:"revenueShare"};
    if(m[e.key])goPage(m[e.key]);
  });
}
window.addEventListener("DOMContentLoaded",init);
</script>

